{
  "name": "gabriela-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "sass": "sass src/scss/main.scss dist/css/main.css --watch",

    "js-build": "esbuild src/js/main.js --bundle --minify --outfile=dist/js/main.js",

    "js-watch": "chokidar \"src/js/**/*.js\" -c \"npm run js-build\" --initial",

    "dev": "npm-run-all --parallel sass js-watch"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "chokidar-cli": "^3.0.0",
    "npm-run-all": "^4.1.5"
  }
}

